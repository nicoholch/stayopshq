# ── Supabase ──────────────────────────────────────────────────────────
# Found in: Supabase dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here   # Server-only, never expose to client

# ── Stripe ────────────────────────────────────────────────────────────
# Found in: Stripe dashboard → Developers → API Keys
STRIPE_SECRET_KEY=sk_live_...          # Use sk_test_... during development
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...        # From: stripe listen --forward-to localhost:3000/api/webhook

# ── Stripe Price IDs ──────────────────────────────────────────────────
# Create these in Stripe Dashboard → Products
STRIPE_PRICE_STARTER=price_...         # $149/month
STRIPE_PRICE_PRO=price_...             # $349/month

# ── App ───────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000   # Change to https://pulsestay.com in production
